# Monad testnet RPC
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Funder key: deploys the implementation, funds/delegates the demo EOAs,
# submits Path A bundles. Needs ~40 testnet MON.
FUNDER_KEY=

# Deployed Mip4Account implementation (output of script/DeployMip4Account.s.sol)
MIP4_ACCOUNT_IMPL=

# Alto bundler keys (comma-separated executors). Gas-only senders never
# violate Monad's reserve (the sender threshold pre-discounts gas fees), so
# no 10 MON headroom is needed: ~2.5 MON per executor, ~3 MON for the
# utility key (it deploys simulation contracts, and Monad charges gas LIMIT,
# not gas used — deploys cost ~0.4-0.5 MON each).
ALTO_EXECUTOR_KEYS=
ALTO_UTILITY_KEY=

# Alto RPC endpoint for demo Path B
ALTO_RPC=http://localhost:4337

# Demo account keys (Alice/Bob/Carol). Leave empty to let setup-testnet.ts
# generate them and write demo/.accounts.json
DEMO_KEYS=
